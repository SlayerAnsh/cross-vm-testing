/target
.env
.env.*
!.env.example

# Solidity (Foundry)
contracts/solidity/out/
contracts/solidity/cache/
contracts/solidity/lib/

# Solana (Anchor)
contracts/solana/target/
contracts/solana/.anchor/

# CosmWasm
contracts/cosmwasm/counter/target/
contracts/cosmwasm/vault/target/

# Tron (Tronbox)
contracts/tron/generated/
contracts/tron/build/
contracts/tron/node_modules/

# Example scripts (Rust build output)
examples/scripts/target/

artifacts/

#IDE
.vscode/

# AI
.claude/
# Stray per-crate target dirs (e.g. replay artifacts written to <crate>/target/cross-vm by CLI e2e tests)
crates/*/target/
examples/integration-tests/target/

# Test-generated artifacts/reports (redirected to <crate>/tests_result/ instead of any target/ dir)
tests_result/
**/tests_result/
